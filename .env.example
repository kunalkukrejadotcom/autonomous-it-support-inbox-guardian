# Autonomous IT Support Inbox Guardian Environment Variables

# Arize Phoenix API Key for tracing (if using Phoenix Cloud)
PHOENIX_API_KEY=your_phoenix_api_key_here

# GCP Configuration
GCP_PROJECT_ID=your_gcp_project_id_here
FIRESTORE_DATABASE_ID=(default)

# Target email inbox for IT support tickets (e.g. support@example.com)
INBOX_EMAIL=support@example.com

# Gemini API Key for LLM operations
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Name — controls which model the agent and self-eval loop use.
# Latest models (Gemini 3.x): gemini-3.5-flash | gemini-3.1-pro | gemini-3.1-flash-lite
# Stable models (Gemini 2.5): gemini-2.5-flash | gemini-2.5-pro
# Legacy models (Gemini 1.5): gemini-1.5-flash | gemini-1.5-pro | gemini-1.5-flash-8b
GEMINI_MODEL=gemini-2.5-flash
